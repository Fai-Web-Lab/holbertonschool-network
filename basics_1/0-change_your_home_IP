#!/usr/bin/env bash
# Configures local host resolution mappings in /etc/hosts

# Replace 127.0.0.1 with 127.0.0.2 for localhost regardless of tab or space spacing
sudo sed -i -E 's/127\.0\.0\.1([[:space:]]+)localhost/127.0.0.2\1localhost/g' /etc/hosts 2>/dev/null || sed -i -E 's/127\.0\.0\.1([[:space:]]+)localhost/127.0.0.2\1localhost/g' /etc/hosts

# Append facebook.com resolution to 8.8.8.8 if it doesn't already exist
if ! grep -q "facebook.com" /etc/hosts; then
    echo -e "8.8.8.8\tfacebook.com" | sudo tee -a /etc/hosts > /dev/null || echo -e "8.8.8.8\tfacebook.com" >> /etc/hosts
fi
